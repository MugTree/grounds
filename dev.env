VT_APP_ENV=development

# Postgres connection
VT_DB_USER=app
VT_DB_PASSWORD=secret
VT_DB_NAME=appdb
VT_DB_HOST=localhost
VT_DB_PORT=5432

# Goose migration settings
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://${VT_DB_USER}:${VT_DB_PASSWORD}@localhost:${VT_DB_PORT}/${VT_DB_NAME}
GOOSE_MIGRATION_DIR=./data/migrations
GOOSE_TABLE=custom.goose_migrations

# App settings
VT_APP_PORT=8080
VT_APP_LOG=./log/app.log
