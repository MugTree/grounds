VT_APP_ENV=docker

# Postgres connection
VT_DB_USER=app
VT_DB_PASSWORD=secret
VT_DB_NAME=appdb
VT_DB_HOST=db
VT_DB_PORT=5432

# App settings
VT_APP_PORT=8080
VT_APP_LOG=./log/app.log

# Caddy Settings
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

VT_WEB_ADDRESS=:3000
VT_REVERSE_PROXY_ADDRESS=app:${VT_APP_PORT}